{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "backend": {
      "source": {
        "repo": "reaLm74/pneumaticworkflow",
        "branch": "master",
        "rootDirectory": "backend"
      },
      "build": {
        "builder": "DOCKERFILE"
      },
      "deploy": {
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
      },
      "networking": {
        "serviceDomain": {}
      },
      "variables": {
        "POSTGRES_PASSWORD": "${{Postgres.POSTGRES_PASSWORD}}",
        "POSTGRES_REPLICA_PASSWORD": "${{Postgres.POSTGRES_PASSWORD}}",
        "CACHE_REDIS_URL": "redis://default:${{Redis.REDISPASSWORD}}@${{Redis.RAILWAY_PRIVATE_DOMAIN}}:6379/0",
        "AUTH_REDIS_URL": "redis://default:${{Redis.REDISPASSWORD}}@${{Redis.RAILWAY_PRIVATE_DOMAIN}}:6379/1",
        "CHANNELS_REDIS_URL": "redis://default:${{Redis.REDISPASSWORD}}@${{Redis.RAILWAY_PRIVATE_DOMAIN}}:6379/2",
        "SESSION_REDIS_URL": "redis://default:${{Redis.REDISPASSWORD}}@${{Redis.RAILWAY_PRIVATE_DOMAIN}}:6379/3",
        "CELERY_BROKER_URL": "amqp://rabbitmq_user:rabbitmq_password@${{rabbitmq.RAILWAY_PRIVATE_DOMAIN}}:5672",
        "BACKEND_URL": "https://${{RAILWAY_PUBLIC_DOMAIN}}",
        "FRONTEND_URL": "https://${{frontend.RAILWAY_PUBLIC_DOMAIN}}",
        "FORMS_URL": "https://${{frontend.RAILWAY_PUBLIC_DOMAIN}}",
        "ALLOWED_HOSTS": "${{RAILWAY_PUBLIC_DOMAIN}} ${{RAILWAY_PRIVATE_DOMAIN}} localhost",
        "CORS_ORIGIN_WHITELIST": "https://${{frontend.RAILWAY_PUBLIC_DOMAIN}} https://${{RAILWAY_PUBLIC_DOMAIN}}"
      }
    },
    "frontend": {
      "source": {
        "repo": "reaLm74/pneumaticworkflow",
        "branch": "master",
        "rootDirectory": "frontend"
      },
      "build": {
        "builder": "DOCKERFILE"
      },
      "deploy": {
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
      },
      "networking": {
        "serviceDomain": {}
      },
      "variables": {
        "BACKEND_URL": "https://${{backend.RAILWAY_PUBLIC_DOMAIN}}",
        "BACKEND_PRIVATE_URL": "https://${{backend.RAILWAY_PUBLIC_DOMAIN}}",
        "WSS_URL": "wss://${{backend.RAILWAY_PUBLIC_DOMAIN}}",
        "FRONTEND_URL": "https://${{RAILWAY_PUBLIC_DOMAIN}}"
      }
    },
    "celery-worker": {
      "source": {
        "repo": "reaLm74/pneumaticworkflow",
        "branch": "master",
        "rootDirectory": "backend"
      },
      "build": {
        "builder": "DOCKERFILE"
      },
      "deploy": {
        "startCommand": "celery --app src.celery_app:app worker -l warning",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
      },
      "variables": {
        "POSTGRES_PASSWORD": "${{Postgres.POSTGRES_PASSWORD}}",
        "POSTGRES_REPLICA_PASSWORD": "${{Postgres.POSTGRES_PASSWORD}}",
        "CACHE_REDIS_URL": "redis://default:${{Redis.REDISPASSWORD}}@${{Redis.RAILWAY_PRIVATE_DOMAIN}}:6379/0",
        "AUTH_REDIS_URL": "redis://default:${{Redis.REDISPASSWORD}}@${{Redis.RAILWAY_PRIVATE_DOMAIN}}:6379/1",
        "CHANNELS_REDIS_URL": "redis://default:${{Redis.REDISPASSWORD}}@${{Redis.RAILWAY_PRIVATE_DOMAIN}}:6379/2",
        "SESSION_REDIS_URL": "redis://default:${{Redis.REDISPASSWORD}}@${{Redis.RAILWAY_PRIVATE_DOMAIN}}:6379/3",
        "CELERY_BROKER_URL": "amqp://rabbitmq_user:rabbitmq_password@${{rabbitmq.RAILWAY_PRIVATE_DOMAIN}}:5672",
        "BACKEND_URL": "https://${{backend.RAILWAY_PUBLIC_DOMAIN}}",
        "FRONTEND_URL": "https://${{frontend.RAILWAY_PUBLIC_DOMAIN}}"
      }
    },
    "celery-beat": {
      "source": {
        "repo": "reaLm74/pneumaticworkflow",
        "branch": "master",
        "rootDirectory": "backend"
      },
      "build": {
        "builder": "DOCKERFILE"
      },
      "deploy": {
        "startCommand": "celery --pidfile= --app src.celery_app:app beat -l warning -S django",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
      },
      "variables": {
        "POSTGRES_PASSWORD": "${{Postgres.POSTGRES_PASSWORD}}",
        "POSTGRES_REPLICA_PASSWORD": "${{Postgres.POSTGRES_PASSWORD}}",
        "CACHE_REDIS_URL": "redis://default:${{Redis.REDISPASSWORD}}@${{Redis.RAILWAY_PRIVATE_DOMAIN}}:6379/0",
        "AUTH_REDIS_URL": "redis://default:${{Redis.REDISPASSWORD}}@${{Redis.RAILWAY_PRIVATE_DOMAIN}}:6379/1",
        "CHANNELS_REDIS_URL": "redis://default:${{Redis.REDISPASSWORD}}@${{Redis.RAILWAY_PRIVATE_DOMAIN}}:6379/2",
        "SESSION_REDIS_URL": "redis://default:${{Redis.REDISPASSWORD}}@${{Redis.RAILWAY_PRIVATE_DOMAIN}}:6379/3",
        "CELERY_BROKER_URL": "amqp://rabbitmq_user:rabbitmq_password@${{rabbitmq.RAILWAY_PRIVATE_DOMAIN}}:5672",
        "BACKEND_URL": "https://${{backend.RAILWAY_PUBLIC_DOMAIN}}",
        "FRONTEND_URL": "https://${{frontend.RAILWAY_PUBLIC_DOMAIN}}"
      }
    },
    "rabbitmq": {
      "source": {
        "image": "rabbitmq:3.13-management"
      },
      "deploy": {
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
      },
      "variables": {
        "RABBITMQ_DEFAULT_USER": "rabbitmq_user",
        "RABBITMQ_DEFAULT_PASS": "rabbitmq_password"
      }
    },
    "Postgres": {
      "plugin": "postgresql"
    },
    "Redis": {
      "plugin": "redis"
    }
  }
}
